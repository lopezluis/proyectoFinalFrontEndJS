function mostrarAyuda()
{
  mensajeInicial
  modoEmpleo
  exit 0
}
function mensajeInicial()
{
  echo -en "Utilidad para copiar la web de Supermercado a Casa con CSS puro hacia apache2 para publicarlo. Versión 1.0.\n\n"
}
function modoEmpleo()
{
  echo -en "Modo de empleo:\n"
  echo -en "    ${0} [modificadores]\n"
  echo -en "Donde modificadores pueden ser:\n"
  echo -en "    --help o -h: muestra éste texto de ayuda y regresa al intérprete de comandos.\n"
}
function copiar()
{
  if /usr/bin/test -f ${2}
  then if /usr/bin/test $(/usr/bin/stat -c %Y ${1}) -gt $(/usr/bin/stat -c %Y ${2})
  then /usr/bin/cp --verbose --recursive --force ${1} ${2}
  fi
  else /usr/bin/cp --verbose --recursive --force ${1} ${2}
  fi
}
